services:
  # ──── NoneBot2 + subflow 插件 ────
  nonebot:
    build: .
    image: subflow-bot:latest
    container_name: subflow-bot
    restart: unless-stopped
    # 不用 env_file —— 用文件挂载，改 .env 后 `docker compose restart nonebot` 即可，无需 down+up
    ports:
      - "8080:8080"  # OneBot v11 反向 WS / HTTP API；NapCat 连这里
    volumes:
      - ./data:/app/data     # 持久化 bindings/pipelines/episode_pipelines
      - ./.env:/app/.env:ro  # 环境变量文件，NoneBot 启动时从 cwd 的 .env 读取
    # 启用容器化 NapCat 时取消下面 4 行注释
    # depends_on:
    #   napcat:
    #     condition: service_started
    networks:
      - subflow-net

  # ──── NapCat（QQ 协议层）默认注释 ────
  # 已有外部 NapCat 实例时保持注释，改 .env 里 ONEBOT_WS_URLS 指向它即可
  #
  # napcat:
  #   image: mlikiowa/napcat-docker:latest
  #   container_name: subflow-napcat
  #   restart: unless-stopped
  #   environment:
  #     - ACCOUNT=          # Bot 的 QQ 账号
  #     - WS_ENABLE=true
  #     - WS_URLS=["ws://nonebot:8080/onebot/v11/ws"]
  #     - NAPCAT_GID=1000
  #     - NAPCAT_UID=1000
  #   ports:
  #     - "6099:6099"       # NapCat WebUI（扫码登录）
  #   volumes:
  #     - napcat-data:/app/.config/QQ
  #   networks:
  #     - subflow-net

networks:
  subflow-net:
    driver: bridge

# volumes:
#   napcat-data:
